{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/taoyangcloud/azpolicylens/schemas/2025-09-01/security-control.json",
  "title": "Custom Security Control Config Schema",
  "type": "object",
  "properties": {
    "ControlID": {
      "type": "string",
      "pattern": "^\\S+$"
    },
    "Category": {
      "type": "string"
    },
    "Name": {
      "type": "string"
    },
    "Description": {
      "type": "string"
    },
    "Publisher": {
      "type": "string"
    },
    "Framework": {
      "type": "string"
    },
    "AdditionalInfo": {
      "type": "object"
    }
  },
  "required": [
    "ControlID",
    "Category",
    "Name",
    "Description",
    "Publisher",
    "Framework",
    "AdditionalInfo"
  ]
}
