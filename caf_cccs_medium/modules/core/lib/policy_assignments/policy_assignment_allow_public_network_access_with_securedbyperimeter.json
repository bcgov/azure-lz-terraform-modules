{
  "name": "Allow-Public-Network-Access-With-SecuredByPerimeter",
  "type": "Microsoft.Authorization/policyAssignments",
  "apiVersion": "2019-09-01",
  "properties": {
    "displayName": "Allow Public Network Access with SecuredByPerimeter",
    "description": "This Policy will allow users to create resources with public network access if they are secured by a perimeter.",
    "notScopes": [],
    "parameters": {
      "resourceTypeConfigurations": {
        "value": [
          {
            "resourceType": "Microsoft.Sql/servers",
            "publicNetworkAccessAlias": "Microsoft.Sql/servers/publicNetworkAccess"
          },
          {
            "resourceType": "Microsoft.Storage/storageAccounts",
            "publicNetworkAccessAlias": "Microsoft.Storage/storageAccounts/publicNetworkAccess"
          },
          {
            "resourceType": "Microsoft.KeyVault/vaults",
            "publicNetworkAccessAlias": "Microsoft.KeyVault/vaults/publicNetworkAccess"
          }
        ]
      },
      "effect": {
        "value": "Deny"
      }
    },
    "policyDefinitionId": "${root_scope_resource_id}/providers/Microsoft.Authorization/policyDefinitions/Allow-Public-Network-Access-With-SecuredByPerimeter",
    "nonComplianceMessages": [
      {
        "message": "Public network access is only allowed when configured as SecuredByPerimeter or Disabled."
      }
    ],
    "scope": "${current_scope_resource_id}",
    "enforcementMode": "Default"
  },
  "location": "${default_location}",
  "identity": {
    "type": "SystemAssigned"
  }
}
