      "deny_ai_hubs": {
        "value": "Audit"
      },
      "deny_azure_openai": {
        "value": "Audit"
      },
      "deny_ai_search": {
        "value": "Audit"
      },
      "deny_bot_services": {
        "value": "Audit"
      },
      "deny_computer_vision": {
        "value": "Audit"
      },
      "deny_custom_vision": {
        "value": "Audit"
      },
      "deny_content_safety": {
        "value": "Audit"
      },
      "deny_document_intelligence": {
        "value": "Audit"
      },
      "deny_face_api": {
        "value": "Audit"
      },
      "deny_health_insights": {
        "value": "Audit"
      },
      "deny_machine_learning": {
        "value": "Audit"
      },
      "deny_immersive_reader": {
        "value": "Audit"
      },
      "deny_language_service": {
        "value": "Audit"
      },
      "deny_speech_service": {
        "value": "Audit"
      },
      "deny_translator": {
        "value": "Audit"
      }
