      {
        "message": "Provisioning Azure AI Services in the Landing Zones is restricted to the AI Services Hub. Please see TechDocs for more information on how to request use of the AI Services Hub: https://developer.gov.bc.ca/docs/default/component/public-cloud-techdocs/azure/azure-services/azure-ai/"
      }
    ],
    "scope": "${current_scope_resource_id}",
    "enforcementMode": "Default"
  },
  "location": "${default_location}",
  "identity": {
    "type": "SystemAssigned"
  }
