{
  "name": "Deny-Copilot-Studio",
  "type": "Microsoft.Authorization/policyAssignments",
  "apiVersion": "2026-06-01",
  "properties": {
    "displayName": "Deny Creating Copilot Studio",
    "description": "This policy prevents users from creating Copilot Studio resources in Power Platform environments.",
    "notScopes": [],
    "parameters": {
      "effect": {
        "value": "Audit"
      }
    },
    "policyDefinitionId": "${current_scope_resource_id}/providers/Microsoft.Authorization/policyDefinitions/Deny-Copilot-Studio",
    "nonComplianceMessages": [
      {
        "message": "Deploying Copilot Studio resources is restricted in this Landing Zone."
      }
    ],
    "scope": "${current_scope_resource_id}",
    "enforcementMode": "Default"
  },
  "location": "${default_location}",
  "identity": {
    "type": "SystemAssigned"
  }
}
