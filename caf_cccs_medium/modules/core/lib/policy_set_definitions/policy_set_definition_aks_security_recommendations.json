{
  "name": "AKS-Security-Best-Practices",
  "type": "Microsoft.Authorization/policySetDefinitions",
  "apiVersion": "2026-01-01-preview",
  "scope": null,
  "properties": {
    "policyType": "Custom",
    "displayName": "Enforce AKS security best practices",
    "description": "This initiative enforces security best practices for Azure Kubernetes Service (AKS) clusters, including network configuration, authentication, and add-on policies. By implementing these policies, you can enhance the security posture of your AKS clusters and ensure compliance with organizational standards.",
    "metadata": {
      "version": "1.0.0",
      "category": "Kubernetes"
    },
    "parameters": {
      "effect_CNI": {
        "type": "String",
        "metadata": {
          "displayName": "Effect (CNI)",
          "description": "Enable or disable the execution of the Azure CNI policy"
        },
        "allowableValues": [
          "Audit",
          "Disabled"
        ],
        "defaultValue": "Audit"
      },
      "effect_CNI_overlay": {
        "type": "String",
        "metadata": {
          "displayName": "Effect (CNI Overlay)",
          "description": "Enable or disable the execution of the Azure CNI Overlay policy"
        },
        "allowableValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Audit"
      },
      "effect_zones": {
        "type": "String",
        "metadata": {
          "displayName": "Effect (Zones)",
          "description": "This parameter lets you choose the effect of the policy. If you choose Audit (default), the policy will only audit resources for compliance. If you choose Deny, the policy will deny the creation of non-compliant resources. If you choose Disabled, the policy will not enforce compliance (useful, for example, as a second assignment to ignore a subset of non-compliant resources in a single resource group)."
        },
        "allowableValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Audit"
      },
      "effect_entra_id": {
        "type": "String",
        "metadata": {
          "displayName": "Effect (Entra ID integration)",
          "description": "Enable or disable the execution of the Entra ID Integration policy."
        },
        "allowableValues": [
          "Audit",
          "Disabled"
        ],
        "defaultValue": "Audit"
      },
      "effect_rbac": {
        "type": "String",
        "metadata": {
          "displayName": "Effect (RBAC)",
          "description": "Enable or disable the execution of the RBAC policy."
        },
        "allowableValues": [
          "Audit",
          "Disabled"
        ],
        "defaultValue": "Audit"
      },
      "effect_azure_rbac": {
        "type": "String",
        "metadata": {
          "displayName": "Effect (Azure RBAC)",
          "description": "Enable or disable the execution of the Azure RBAC policy."
        },
        "allowableValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Audit"
      },
      "effect_local_auth": {
        "type": "String",
        "metadata": {
          "displayName": "Effect (Local Auth Disabled)",
          "description": "Enable or disable the execution of the policy."
        },
        "allowableValues": [
          "Audit",
          "Deny",
          "Disabled"
        ],
        "defaultValue": "Audit"
      },
