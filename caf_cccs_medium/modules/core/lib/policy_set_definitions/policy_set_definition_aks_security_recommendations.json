          "displayName": "Effect (Image Cleaner Audit)",
          "description": "Enable or disable the execution of the Image Cleaner Audit policy."
        },
        "allowableValues": [
          "Audit",
          "Disabled"
        ],
        "defaultValue": "Audit"
      }
