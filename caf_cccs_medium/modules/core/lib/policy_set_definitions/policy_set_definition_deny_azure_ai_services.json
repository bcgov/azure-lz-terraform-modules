{
  "name": "Deny-Azure-AI-Services-Initiative",
  "type": "Microsoft.Authorization/policySetDefinitions",
  "apiVersion": "2026-01-01-preview",
  "scope": null,
  "properties": {
    "policyType": "Custom",
    "displayName": "Deny deployment of selected Azure AI Services",
    "description": "This initiative denies deployment of selected Azure AI Services and supports per-policy exemptions through stable policy definition reference IDs.",
    "metadata": {
      "version": "1.0.0",
      "category": "AI"
    },
    "parameters": {
      "deny_ai_foundry": {
        "type": "String",
        "metadata": {
          "displayName": "Deny Azure AI Foundry services",
          "description": "Controls whether creation of Azure AI Foundry services is denied, audited, or disabled."
        },
        "defaultValue": "Audit"
      },
      "deny_ai_hubs": {
        "type": "String",
        "metadata": {
          "displayName": "Deny Azure AI Hubs",
          "description": "Controls whether creation of Azure AI Hubs is denied, audited, or disabled."
        },
        "defaultValue": "Audit"
      },
