{
  "name": "Deny-AI-Search",
  "type": "Microsoft.Authorization/policyDefinitions",
  "apiVersion": "2026-06-01",
  "properties": {
    "displayName": "Deny Creating Azure AI Search Services",
    "description": "This policy prevents users from creating Azure AI Search Services.",
    "policyType": "Custom",
    "mode": "All",
    "metadata": {
      "version": "1.0.0",
      "category": "Azure Ai Services"
    },
    "parameters": {
      "effect": {
        "type": "String",
        "metadata": {
          "displayName": "Effect",
          "description": "Select whether the policy is enforced (Deny), evaluated (Audit), or turned off (Disabled)."
        },
        "allowedValues": [
          "Deny",
          "Audit",
          "Disabled"
        ],
        "defaultValue": "Audit"
      }
    },
    "policyRule": {
      "if": {
        "field": "type",
        "equals": "Microsoft.Search/searchServices"
      },
      "then": {
        "effect": "[parameters('effect')]"
      }
    }
  }
}
